    ],
  },
  {
    category: 'Quality & Tooling',
    icon: 'fa-wrench',
    items: [
      { name: 'Git', tip: 'Version control — daily use' },
      { name: 'pytest', tip: 'Unit testing for Python projects' },
      { name: 'mypy', tip: 'Static type checking for Python' },
    ],
  },
  {
    category: 'AI & APIs',
    icon: 'fa-robot',
    items: [
      { name: 'OpenAI API', tip: 'Built projects integrating GPT models' },
      { name: 'Anthropic API', tip: 'Claude API — ongoing personal projects' },
      { name: 'Prompt Engineering', tip: '2+ years daily use of AI tools in development' },

    desc: 'Dishwashing during weekend service and responsible for cleaning the venue on Sundays.',
  },
  {
    icon: 'fa-mug-hot',
    period: 'Mar 2018 – Sep 2018',
    title: 'Blafre Café',
    sub: 'Café Employee / Barista',
    desc: 'Prepared food and coffee, handled cash register, inventory, and daily operations.',
  },
  {
    icon: 'fa-table-tennis-paddle-ball',
    period: 'Jan 2014 – Jan 2015',
    title: 'Grefsen Tennisklubb',
    sub: 'Tennis Instructor',
    desc: 'Coached children twice weekly and planned training sessions focused on progress and enjoyment.',
  },

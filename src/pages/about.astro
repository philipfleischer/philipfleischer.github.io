    icon: 'fa-mobile-screen',
    items: [
      { name: 'Android', tip: 'Native Android app development' },
      { name: 'Jetpack Compose', tip: 'Declarative UI toolkit for Android' },
      { name: 'Ktor', tip: 'HTTP client for Kotlin' },
      { name: 'MapLibre', tip: 'Maps and geo-visualisation on Android' },
    ],
  },
  {
    category: 'Cloud & DevOps',
    icon: 'fa-cloud',
    items: [
      { name: 'Docker', tip: 'Containerisation — basic hands-on experience' },
      { name: 'Terraform', tip: 'Infrastructure as Code — basic, used with Azure' },
      { name: 'Azure', tip: 'Microsoft cloud — basic, used in Terraform lab' },
      { name: 'GitHub Actions', tip: 'CI/CD — set up for this portfolio' },

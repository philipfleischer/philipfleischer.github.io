const education = [
  {
    icon: 'fa-graduation-cap',
    period: '2021 – 2026',
    title: 'University of Oslo',
    sub: 'BSc Computer Science (Informatics: Programming & System Architecture)',
    desc: 'Expected graduation Spring 2026. I took a year off in 2023–2024 and came back in 2024, running first and second year courses at the same time to catch up.',

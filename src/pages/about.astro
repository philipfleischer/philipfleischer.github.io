      { name: 'Python', tip: 'Scripting, tooling, ML, and scientific computing' },
      { name: 'Java', tip: 'Object-oriented programming' },
      { name: 'Kotlin', tip: 'Android development and course projects' },
      { name: 'JavaScript', tip: 'Frontend and backend scripting' },
    ],
  },
  {
    category: 'Web & Frontend',
    icon: 'fa-globe',
    items: [
      { name: 'HTML / CSS', tip: 'Semantic markup and responsive layouts' },
      { name: 'SCSS', tip: 'Modular styling with design tokens' },
      { name: 'JavaScript', tip: 'Vanilla JS and DOM scripting' },
      { name: 'TypeScript', tip: 'Typed JS — picked up building this site' },
      { name: 'React', tip: 'Component-based UI — basic experience' },
    ],
  },
  {
    category: 'Backend & Databases',
    icon: 'fa-server',
    items: [
      { name: 'Node.js', tip: 'Server-side JavaScript runtime' },
      { name: 'Express', tip: 'REST API development with Node' },

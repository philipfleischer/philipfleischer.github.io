  {
    icon: 'fa-compass',
    period: '2024 – 2026',
    title: 'Academic specialisation',
    sub: 'Systems, Networks & Backend',
    desc: 'IN3000 OS, IN3230 Networks, IN3130 Algorithms, IN2120 Information Security, IN2010 Data Structures. See the Courses page for full detail.',
  },
  {
    icon: 'fa-book',
    period: 'Selected courses',
    title: 'UiO coursework highlights',
    sub: 'See Courses section for full detail',
    desc: 'IN3000 OS, IN3020 Databases, IN3230 Networks, IN3130 Algorithms, IN2120 Information Security, IN2010 Data Structures.',
  },
  {
    icon: 'fa-school',
    period: '2018 – 2021',
    title: 'Foss High School',
    sub: 'General Studies',
    desc: 'General studies. Participated in academic summer programmes (nanotechnology at UiO).',

---
export interface Props {
  title: string;
  subtitle: string;
  image: string;
  tags: string[];
  topics: string[];
  links: { label: string; url: string }[];
  slug: string;
  detailPath: string;  // e.g. /projects/slug or /courses/slug
}

const { title, subtitle, image, tags, links, topics, slug, detailPath } = Astro.props;
---

<article
  class="card"
  data-topics={topics.join(',')}
>
  <a href={detailPath} class="card__media-link" tabindex="-1" aria-hidden="true">
    <div class="card__media">
      <img src={image} alt={title} loading="lazy" width="400" height="220" />
    </div>
  </a>

  <div class="card__body">
    <div class="card__header">
      <a href={detailPath} class="card__title-link">
        <h3 class="card__title">{title}</h3>
      </a>
      <p class="card__subtitle">{subtitle}</p>
    </div>

    <ul class="card__tags" aria-label="Technologies">
      {tags.slice(0, 6).map(t => <li class="tag">{t}</li>)}
      {tags.length > 6 && <li class="tag tag--more">+{tags.length - 6}</li>}
    </ul>

    <div class="card__links">
      <a href={detailPath} class="btn-ghost btn-sm">
        <i class="fa-solid fa-arrow-right fa-xs" aria-hidden="true"></i>
        Details
      </a>
      {links.map(l => (
        <a href={l.url} class="btn-ghost btn-sm" target="_blank" rel="noopener noreferrer">
          {l.label.includes('GitHub') ? (
            <i class="fab fa-github fa-sm" aria-hidden="true"></i>
          ) : (
            <i class="fa-solid fa-arrow-up-right-from-square fa-xs" aria-hidden="true"></i>
          )}
          {l.label}
        </a>
      ))}
    </div>
  </div>
</article>

<style lang="scss">
  @use 'src/styles/variables' as *;

  .card {
    background: $bg-2;
    border: 1px solid $border-subtle;
    border-radius: $r-lg;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-self: start;
    transition: border-color $t-fast $ease, transform $t-fast $ease, box-shadow $t-fast $ease;

    &:hover {
      border-color: $border;
      transform: translateY(-3px);
      box-shadow: $shadow;
    }
  }

  .card__media-link { display: block; }

  .card__media {
    width: 100%;
    height: 190px;
    background: $bg-3;
    overflow: hidden;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(15%);
      transition: filter $t-slow $ease, transform $t-slow $ease;
    }
  }

  .card:hover .card__media img {
    filter: grayscale(0%);
    transform: scale(1.03);
  }

  .card__body {
    padding: $sp-5;
    display: flex;
    flex-direction: column;
    gap: $sp-4;
    flex: 1;
  }

  .card__title-link { text-decoration: none; }

  .card__title {
    font-size: 1.05rem;
    font-weight: 800;
    color: $text;
    margin-bottom: $sp-2;
    transition: color $t-fast $ease;

    .card__title-link:hover & { color: $accent; }
  }

  .card__subtitle {
    font-size: 0.88rem;
    color: $text-muted;
    line-height: 1.6;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: $sp-2;
  }

  .tag--more {
    color: $text-dim;
    border-color: $border-subtle;
  }

  .card__links {
    display: flex;
    flex-wrap: wrap;
    gap: $sp-2;
    margin-top: auto;
  }
</style>

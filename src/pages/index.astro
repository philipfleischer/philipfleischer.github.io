---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Philip Fleischer — Software Engineer">
  <main class="hero-page">

    <div class="hero">
      <div class="hero__photo-col">
        <div class="hero__photo-wrap">
          <img
            src="/img/Profile_pic.png"
            alt="Philip Elias Fleischer"
            class="hero__photo"
            width="340"
            height="420"
          />
        </div>
      </div>

      <div class="hero__text-col">
        <span class="section-eyebrow">Available for internships & junior roles</span>

        <h1 class="hero__name">
          Philip Elias<br />
          <span class="hero__name--accent">Fleischer</span>
        </h1>

        <p class="hero__tagline">
          Computer Science · University of Oslo
        </p>

        <p class="hero__bio">
          CS student at UiO. I'm mainly interested in systems programming, networking,
          and security — I like understanding how things work at a lower level, from
          protocols to operating systems. I also spend a lot of time experimenting
          with AI tools and APIs on the side.
        </p>

        <div class="hero__cta">
          <a href="/portfolio" class="btn-primary">
            <i class="fa-solid fa-briefcase fa-sm" aria-hidden="true"></i>
            View Portfolio
          </a>
          <a href="/contact" class="btn-ghost">
            <i class="fa-regular fa-envelope fa-sm" aria-hidden="true"></i>
            Get in touch
          </a>
          <a
            href="https://github.com/philipfleischer"
            class="btn-ghost"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fab fa-github fa-sm" aria-hidden="true"></i>
            GitHub
          </a>
        </div>

        <div class="hero__highlights">
          <div class="highlight">
            <span class="highlight__value">2026</span>
            <span class="highlight__label">BSc Computer Science, UiO</span>
          </div>
          <div class="highlight__sep" aria-hidden="true"></div>
          <div class="highlight">
            <span class="highlight__value">Systems & Networks</span>
            <span class="highlight__label">Primary focus area</span>
          </div>
          <div class="highlight__sep" aria-hidden="true"></div>
          <div class="highlight">
            <span class="highlight__value">Oslo, Norway</span>
            <span class="highlight__label">Open to remote & hybrid</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick-nav cards -->
    <section class="quick-nav">
      <a href="/about" class="quick-card">
        <i class="fa-solid fa-layer-group" aria-hidden="true"></i>
        <div>
          <h3>Skills &amp; Timeline</h3>
          <p>Languages, tools, and background</p>
        </div>
        <i class="fa-solid fa-arrow-right quick-card__arrow" aria-hidden="true"></i>
      </a>
      <a href="/portfolio" class="quick-card">
        <i class="fa-solid fa-code-branch" aria-hidden="true"></i>
        <div>
          <h3>Projects</h3>
          <p>Things I've built and worked on</p>
        </div>
        <i class="fa-solid fa-arrow-right quick-card__arrow" aria-hidden="true"></i>
      </a>
      <a href="/courses" class="quick-card">
        <i class="fa-solid fa-graduation-cap" aria-hidden="true"></i>
        <div>
          <h3>Course Work</h3>
          <p>University assignments and labs</p>
        </div>
        <i class="fa-solid fa-arrow-right quick-card__arrow" aria-hidden="true"></i>
      </a>
    </section>

  </main>
</Layout>

<style lang="scss">
  @use 'src/styles/variables' as *;

  .hero-page {
    min-height: calc(100dvh - #{$nav-h});
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: $sp-12 $page-px $sp-8;
    max-width: $content-max;
    margin: 0 auto;
  }

  // ── Hero layout ──────────────────────────────────────────────────
  .hero {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: $sp-12;
    align-items: center;
    margin-bottom: $sp-16;

    @media (max-width: 900px) {
      grid-template-columns: 1fr;
      gap: $sp-8;
    }
  }

  // ── Photo ────────────────────────────────────────────────────────
  .hero__photo-col {
    @media (max-width: 900px) {
      display: flex;
      justify-content: center;
    }
  }

  .hero__photo-wrap {
    position: relative;
    width: 280px;
    height: 340px;
    border-radius: $r-xl;
    overflow: hidden;
    border: 1px solid $border;
    box-shadow: $shadow-lg;

    // subtle accent glow underneath
    &::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: $r-xl;
      background: linear-gradient(135deg, $accent 0%, transparent 60%);
      opacity: 0.18;
      z-index: 0;
    }
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    position: relative;
    z-index: 1;
  }

  // ── Text ─────────────────────────────────────────────────────────
  .hero__text-col {
    display: flex;
    flex-direction: column;
    gap: $sp-4;
  }

  .hero__name {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.1;
    color: $text;
    letter-spacing: -0.02em;
  }

  .hero__name--accent { color: $accent; }

  .hero__tagline {
    font-size: 0.95rem;
    font-weight: 600;
    color: $text-dim;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero__bio {
    font-size: 1rem;
    color: $text-muted;
    line-height: 1.8;
    max-width: 560px;
    margin: $sp-2 0;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: $sp-3;
  }

  // ── Highlights ───────────────────────────────────────────────────
  .hero__highlights {
    display: flex;
    align-items: center;
    gap: $sp-5;
    flex-wrap: wrap;
    margin-top: $sp-4;
    padding-top: $sp-5;
    border-top: 1px solid $border-subtle;
  }

  .highlight {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .highlight__value {
    font-weight: 700;
    font-size: 0.95rem;
    color: $text;
  }

  .highlight__label {
    font-size: 0.78rem;
    color: $text-dim;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .highlight__sep {
    width: 1px;
    height: 36px;
    background: $border-subtle;

    @media (max-width: 540px) { display: none; }
  }

  // ── Quick-nav cards ──────────────────────────────────────────────
  .quick-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: $sp-4;

    @media (max-width: 720px) { grid-template-columns: 1fr; }
  }

  .quick-card {
    display: flex;
    align-items: center;
    gap: $sp-4;
    padding: $sp-5;
    border-radius: $r-lg;
    background: $bg-2;
    border: 1px solid $border-subtle;
    text-decoration: none;
    color: $text;
    transition: border-color $t-fast $ease, background $t-fast $ease,
                transform $t-fast $ease;

    > i:first-child {
      font-size: 1.3rem;
      color: $accent;
      flex-shrink: 0;
      width: 24px;
      text-align: center;
    }

    > div { flex: 1; }

    h3 {
      font-size: 0.95rem;
      font-weight: 700;
      color: $text;
      margin-bottom: 2px;
    }

    p {
      font-size: 0.8rem;
      color: $text-dim;
      margin: 0;
    }

    &:hover {
      border-color: $accent;
      background: $accent-subtle;
      transform: translateY(-2px);
      text-decoration: none;
      h3 { color: $accent; }
    }
  }

  .quick-card__arrow {
    color: $text-dim;
    font-size: 0.8rem;
    flex-shrink: 0;
    transition: color $t-fast $ease, transform $t-fast $ease;
  }

  .quick-card:hover .quick-card__arrow {
    color: $accent;
    transform: translateX(3px);
  }
</style>

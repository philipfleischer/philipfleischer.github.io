const work = [
  {
    icon: 'fa-leaf',
    period: 'Jun 2025 – Sep 2025',
    title: 'Housing Cooperative / Sameie',
    sub: 'Seasonal Maintenance Worker',
    desc: 'Part-time seasonal maintenance — lawn mowing, painting window frames, and general upkeep (~2 hrs/week).',
  },
  {
    icon: 'fa-wine-glass',
    period: 'Jun 2021 – Sep 2022',
    title: 'Nektar Vinbar',
